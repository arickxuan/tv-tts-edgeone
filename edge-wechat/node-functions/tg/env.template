# Telegram Bot
TG_BOT_TOKEN=
TG_CHAT_ID=
# Bot API 代理域名（可选）。默认 https://api.telegram.org
# 可写完整 URL 或仅域名，例如：
# TG_API_BASE=https://tg-proxy.example.com
# TG_PROXY_DOMAIN=tg-proxy.example.com
TG_API_BASE=

# Index backend: redis | pocketbase
# 留空则自动：有 UPSTASH_REDIS_URI 用 redis；否则有 POCKETBASE_URL 用 pocketbase
TGFS_INDEX_BACKEND=redis

# Blob backend 默认值: telegram | github（上传未传 backend 时使用）
# 空或未设置时等同 github
TGFS_BLOB_BACKEND=github

# Redis (Upstash) — TGFS_INDEX_BACKEND=redis
UPSTASH_REDIS_URI=

# PocketBase — TGFS_INDEX_BACKEND=pocketbase；用户注册也走此 URL
# 默认 http://tgnas.arick.bond（POST /api/users/reg）
POCKETBASE_URL=http://tgnas.arick.bond

# 二选一：Admin 账号 或 已有 auth token
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=
# POCKETBASE_AUTH_TOKEN=
#
# 需在 PocketBase Admin 创建集合：
# tgfs_buckets: name(text unique), creation_date(text), backend(text 可选 github|telegram)
# tgfs_objects: bucket, key, parent, name, file_id, message_id(number),
#   size(number), content_type, etag, mtime, is_dir(bool),
#   backend(text 可选), sha(text 可选)
#   建议对 (bucket, key) 建唯一索引

# GitHub 私有仓库存储 — TGFS_BLOB_BACKEND=github
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
# 仓库内路径前缀；留空表示直接写到仓库根下 {bucket}/{key}
# 注意：写成 GITHUB_PATH_PREFIX= 表示无前缀；不写该行才默认 tgfs
GITHUB_PATH_PREFIX=tgfs
# 企业版/代理可改 API 根。若本机 Clash Fake-IP 劫持 api.github.com，
# 需直连或换成可用的 API 代理，例如：
# GITHUB_API_BASE=https://api.github.com
# GITHUB_MAX_UPLOAD_BYTES=104857600

# REST API token (Bearer / X-API-Key)
TGFS_API_TOKEN=
TGFS_DEFAULT_BUCKET=default

# S3-compatible credentials (SigV4)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# WebDAV Basic Auth
DAV_USER=
DAV_PASS=

# Optional size limits (bytes)
# TG_MAX_UPLOAD_BYTES=52428800
# TG_MAX_DOWNLOAD_BYTES=20971520

# Local server
# PORT=3000
