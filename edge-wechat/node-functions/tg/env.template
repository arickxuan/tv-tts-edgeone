# Telegram Bot
TG_BOT_TOKEN=
TG_CHAT_ID=
# Bot API 代理域名（可选）。默认 https://api.telegram.org
# 可写完整 URL 或仅域名，例如：
# TG_API_BASE=https://tg-proxy.example.com
# TG_PROXY_DOMAIN=tg-proxy.example.com
TG_API_BASE=

# Index backend: redis | pocketbase
# 留空则自动：有 UPSTASH_REDIS_URI 用 redis；否则有 POCKETBASE_URL 用 pocketbase
TGFS_INDEX_BACKEND=redis

# Redis (Upstash) — TGFS_INDEX_BACKEND=redis
UPSTASH_REDIS_URI=

# PocketBase — TGFS_INDEX_BACKEND=pocketbase
POCKETBASE_URL=http://127.0.0.1:8090
# 二选一：Admin 账号 或 已有 auth token
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=
# POCKETBASE_AUTH_TOKEN=
#
# 需在 PocketBase Admin 创建集合：
# tgfs_buckets: name(text unique), creation_date(text)
# tgfs_objects: bucket, key, parent, name, file_id, message_id(number),
#   size(number), content_type, etag, mtime, is_dir(bool)
#   建议对 (bucket, key) 建唯一索引

# REST API token (Bearer / X-API-Key)
TGFS_API_TOKEN=
TGFS_DEFAULT_BUCKET=default

# S3-compatible credentials (SigV4)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# WebDAV Basic Auth
DAV_USER=
DAV_PASS=

# Optional size limits (bytes)
# TG_MAX_UPLOAD_BYTES=52428800
# TG_MAX_DOWNLOAD_BYTES=20971520

# Local server
# PORT=3000
